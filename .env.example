# === Server ===
# Port the server listens on
# Render.com sets this automatically (default 10000)
# Local development: 8000
PORT=10000

# Node environment: development | production
NODE_ENV=development

# Bind address (0.0.0.0 for all interfaces)
HOSTNAME=0.0.0.0

# === Metered.ca TURN Server ===
# Free tier: 20 GB/month TURN relay traffic (the "Free: 20GB" plan).
# Get your key at: https://dashboard.metered.ca/signup?tool=turnserver
# apiKey is used to generate TURN credentials (/api/turn-credentials).
METERED_API_KEY=your_api_key_here

# secretKey is used to read usage stats (/api/turn-usage, the /usage page).
# Found in Metered → Developers. If omitted, the usage page falls back to
# METERED_API_KEY (which may not have access to the usage endpoint).
METERED_SECRET_KEY=your_secret_key_here
